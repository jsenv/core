{
  "name": "@jsenv/database-manager",
  "version": "0.1.8",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/jsenv/core",
    "directory": "packages/backend/database-manager"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "dev:jsenv": "./index.js",
        "default": "./dist/jsenv_database_manager.js"
      }
    },
    "./*": "./*"
  },
  "main": "./index.js",
  "files": [
    "/dist/",
    "/src/",
    "/index.js"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@jsenv/database": "0.0.10",
    "@jsenv/server": "17.1.1",
    "@jsenv/urls": "2.9.8",
    "@tanstack/table-core": "8.21.3",
    "jsonwebtoken": "9.0.3",
    "postgres": "3.4.8"
  },
  "devDependencies": {
    "@jsenv/core": "../../../",
    "@jsenv/dom": "../../frontend/dom",
    "@jsenv/navi": "../../frontend/navi",
    "@jsenv/plugin-preact": "../../related/plugin-preact",
    "@jsenv/server": "../../server",
    "@preact/signals": "2.9.0",
    "preact": "11.0.0-beta.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
